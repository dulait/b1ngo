{
  "openapi": "3.1.1",
  "info": {
    "title": "B1ngo.Web | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost/"
    }
  ],
  "paths": {
    "/api/v1/rooms": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "CreateRoom",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomCommand"
              }
            },
            "application/*\u002Bjson": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/join": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "JoinRoom",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinRoomCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinRoomCommand"
              }
            },
            "application/*\u002Bjson": {
              "schema": {
                "$ref": "#/components/schemas/JoinRoomCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/reconnect": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "Reconnect",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/start": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "StartGame",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/end": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "EndGame",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}": {
      "get": {
        "tags": [
          "Rooms"
        ],
        "operationId": "GetRoomState",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/players/me/card/squares/{row}/{column}": {
      "put": {
        "tags": [
          "Rooms"
        ],
        "operationId": "EditSquare",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "row",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "column",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditSquareRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EditSquareRequest"
              }
            },
            "application/*\u002Bjson": {
              "schema": {
                "$ref": "#/components/schemas/EditSquareRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/players/{playerId}/card/squares/{row}/{column}/mark": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "MarkSquare",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "playerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "row",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "column",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/rooms/{roomId}/players/{playerId}/card/squares/{row}/{column}/unmark": {
      "post": {
        "tags": [
          "Rooms"
        ],
        "operationId": "UnmarkSquare",
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "playerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "row",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "column",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateRoomCommand": {
        "required": [
          "hostDisplayName",
          "season",
          "grandPrixName",
          "sessionType"
        ],
        "type": "object",
        "properties": {
          "hostDisplayName": {
            "type": "string"
          },
          "season": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "grandPrixName": {
            "type": "string"
          },
          "sessionType": {
            "$ref": "#/components/schemas/SessionType"
          },
          "matrixSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "winningPatterns": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/WinPatternType"
            }
          }
        }
      },
      "EditSquareRequest": {
        "required": [
          "displayText"
        ],
        "type": "object",
        "properties": {
          "displayText": {
            "type": "string"
          }
        }
      },
      "JoinRoomCommand": {
        "required": [
          "joinCode",
          "displayName"
        ],
        "type": "object",
        "properties": {
          "joinCode": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "SessionType": {
        "type": "integer"
      },
      "WinPatternType": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Rooms"
    }
  ]
}